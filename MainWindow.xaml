<Window x:Class="UE57AndroidManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UE57AndroidManager"
        mc:Ignorable="d"
        Title="UE 5.7 Android Setup Manager"
        Height="720" Width="1200"
        Background="#F4F4F4">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Unreal Engine 5.7 Android Setup Tool"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="10"
                   HorizontalAlignment="Left"/>

        <!-- Top Row Buttons -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,20,0,20">

            <!-- Android Studio -->
            <Button Click="DownloadAndroidStudio_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/androidstudio.png" Height="120"/>
                    <TextBlock Text="Android Studio Download"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- SDK + NDK -->
            <Button Click="InstallSDK_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/sdk.png" Height="120"/>
                    <TextBlock Text="Install Required SDK + NDK"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- Verify Unreal -->
            <Button Click="VerifyUE_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/unreal.png" Height="120"/>
                    <TextBlock Text="Verify Unreal Engine Android Support"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- Download JDK -->
            <Button Click="DownloadJDK_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/java.png" Height="120"/>
                    <TextBlock Text="Download JDK 21"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- Verify JDK -->
            <Button Click="VerifyJDK_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/java.png" Height="120"/>
                    <TextBlock Text="Verify JDK 21"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- Second Row Buttons -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,20">

            <!-- Set JAVA_HOME -->
            <Button Click="SetJavaHome_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/java.png" Height="120"/>
                    <TextBlock Text="Set JAVA_HOME"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- Run SetupAndroid -->
            <Button Click="RunSetup_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/unreal.png" Height="120"/>
                    <TextBlock Text="Run SetupAndroid.bat"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

            <!-- Generate Keystore -->
            <Button Click="GenerateKeystore_Click" Margin="10">
                <StackPanel>
                    <Image Source="Images/keystore.png" Height="120"/>
                    <TextBlock Text="Generate Keystore"
                               TextAlignment="Center"
                               FontSize="16"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- Logs Section -->
        <StackPanel Grid.Row="3">

            <TextBlock Text="Logs:"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="10,10,0,10"/>

            <TextBox Name="OutputBox"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="14"
                     Background="#DDDDDD"
                     BorderThickness="0"
                     Height="250"/>

        </StackPanel>

    </Grid>
</Window>