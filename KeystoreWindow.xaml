<Window x:Class="UE57AndroidManager.KeystoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keystore Details" Height="400" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Keystore filename (will be created in Documents):"/>
            <TextBox Name="FileNameBox" Text="ExampleKey.keystore"/>

            <TextBlock Text="Alias:" Margin="0,8,0,0"/>
            <TextBox Name="AliasBox" Text="MyKey"/>

            <TextBlock Text="Store Password:" Margin="0,8,0,0"/>
            <PasswordBox Name="StorePasswordBox" Password="changeit"/>

            <TextBlock Text="Key Password:" Margin="0,8,0,0"/>
            <PasswordBox Name="KeyPasswordBox" Password="changeit"/>

            <TextBlock Text="Common Name (CN):" Margin="0,8,0,0"/>
            <TextBox Name="CNBox" Text="Example"/>

            <TextBlock Text="Organizational Unit (OU):" Margin="0,8,0,0"/>
            <TextBox Name="OUBox" Text="Dev"/>

            <TextBlock Text="Organization (O):" Margin="0,8,0,0"/>
            <TextBox Name="OBox" Text="Company"/>

            <TextBlock Text="Locality (L):" Margin="0,8,0,0"/>
            <TextBox Name="LBox" Text="City"/>

            <TextBlock Text="State (S):" Margin="0,8,0,0"/>
            <TextBox Name="SBox" Text="State"/>

            <TextBlock Text="Country (C):" Margin="0,8,0,0"/>
            <TextBox Name="CBox" Text="US"/>

            <TextBlock Text="Key size:" Margin="0,8,0,0"/>
            <TextBox Name="KeySizeBox" Text="2048"/>

            <TextBlock Text="Validity days:" Margin="0,8,0,0"/>
            <TextBox Name="ValidityBox" Text="10000"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click"/>
                <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>