<Window x:Class="UE57AndroidManager.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Downloading..." Height="150" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Name="StatusText" Text="Starting..." Margin="0,0,0,10"/>
            <ProgressBar Name="ProgressBar" Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Name="BytesText" Text="0 / 0" Margin="0,8,0,0"/>
            <Button Name="CancelButton" Content="Cancel" Width="80" HorizontalAlignment="Right" Margin="0,8,0,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>